{
    "name": "ctf-kiosk",
    "version": "1.2.0",
    "description": "CTF Event Kiosk - Secure Environment",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder --win --x64",
        "build:win": "electron-builder --win --x64",
        "build:mac": "electron-builder --mac",
        "build:linux": "electron-builder --linux",
        "build:all": "electron-builder --win --x64 --linux",
        "pack": "electron-builder --dir",
        "checksum": "node scripts/generate-checksums.js"
    },
    "author": {
        "name": "HackLayer",
        "email": "support@hacklayer.com"
    },
    "homepage": "https://hacklayer.com",
    "license": "UNLICENSED",
    "dependencies": {
        "electron-updater": "^6.3.9"
    },
    "devDependencies": {
        "electron": "^33.2.1",
        "electron-builder": "^25.1.8"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "build": {
        "appId": "com.hacklayer.ctf-kiosk",
        "productName": "HackLayer CTF",
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "icon": "assets/icon.ico",
            "requestedExecutionLevel": "asInvoker"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "artifactName": "HackLayer-CTF-Setup-${version}.${ext}",
            "shortcutName": "HackLayer CTF",
            "uninstallDisplayName": "HackLayer CTF",
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64"
                    ]
                }
            ],
            "icon": "assets/icon.png",
            "category": "public.app-category.education",
            "artifactName": "HackLayer-CTF-${version}-${arch}.${ext}",
            "hardenedRuntime": false,
            "gatekeeperAssess": false
        },
        "dmg": {
            "title": "HackLayer CTF",
            "iconSize": 80,
            "contents": [
                {
                    "x": 130,
                    "y": 220
                },
                {
                    "x": 410,
                    "y": 220,
                    "type": "link",
                    "path": "/Applications"
                }
            ]
        },
        "linux": {
            "target": [
                "AppImage"
            ],
            "icon": "assets/icon.png",
            "category": "Education",
            "artifactName": "HackLayer-CTF-${version}.${ext}",
            "maintainer": "HackLayer <support@hacklayer.com>"
        },
        "files": [
            "**/*",
            "!node_modules/.cache/**"
        ],
        "extraResources": [
            {
                "from": "config.json",
                "to": "config.json"
            }
        ],
        "publish": [
            {
                "provider": "github",
                "owner": "HackLayerX",
                "repo": "hacklayer-ctf"
            },
            {
                "provider": "generic",
                "url": "https://hacklayer.com/downloads/updates"
            }
        ]
    }
}
